# CVE MCP Server - Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://cve_user:changeme@localhost:5432/cve_mcp
DATABASE_URL_SYNC=postgresql://cve_user:changeme@localhost:5432/cve_mcp

# Redis
REDIS_URL=redis://localhost:6379/0

# NVD API (optional but recommended for higher rate limits)
# Get your API key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# OpenAI API Key for semantic search embeddings
OPENAI_API_KEY=sk-...

# MCP Server
MCP_PORT=8307
MCP_HOST=0.0.0.0
MCP_TRANSPORT=http
LOG_LEVEL=INFO
# CORS origins (comma-separated). Defaults to localhost for security.
# For development/internal use, you may set to "*" but this is NOT recommended for production
CORS_ORIGINS=http://localhost,http://localhost:*,http://127.0.0.1,http://127.0.0.1:*

# Sync Configuration
SYNC_WINDOW_START=02:00
SYNC_WINDOW_END=04:00
DATA_FRESHNESS_WARNING_HOURS=48
DATA_FRESHNESS_CRITICAL_HOURS=168

# Performance
QUERY_CACHE_TTL_SECONDS=3600
CVE_DETAILS_CACHE_TTL_SECONDS=86400
MAX_QUERY_RESULTS=500
DEFAULT_QUERY_RESULTS=50

# Audit
AUDIT_LOG_RETENTION_DAYS=2555
