  "security_dimension_summary": {
    "encryption_at_rest": {
      "tier_0_sources": [
        "Organization Policy Constraints API (constraints/gcp.restrictNonCmekServices, constraints/gcp.restrictCmekCryptoKeyProjects)"
      ],
      "tier_2_sources": [
        "Cloud Storage Encryption Documentation (AES-256 GCM, CMEK, CSEK specifications)"
      ],
      "default_behavior": "AES-256 in GCM mode, no configuration required",
      "customer_options": ["Google-managed keys (default)", "Customer-managed keys (CMEK)", "Customer-supplied keys (CSEK)"]
    },
    "encryption_in_transit": {
      "tier_0_sources": [
        "Organization Policy Constraints API (constraints/storage.secureHttpTransport, constraints/gcp.restrictTLSVersion)"
      ],
      "default_behavior": "TLS encryption enforced for all API operations",
      "enforcement": "HTTPS required when secureHttpTransport constraint enabled; TLS 1.2+ when restrictTLSVersion enforced"
    },
    "access_control_iam": {
      "tier_0_sources": [
        "Cloud Storage JSON API (getIamPolicy, setIamPolicy, testIamPermissions)",
        "Organization Policy Constraints API (constraints/storage.uniformBucketLevelAccess)",
