            "security_properties_included": [
              "IAM policies",
              "Encryption settings",
              "Public access configuration",
              "Lifecycle policies",
              "Versioning",
              "Retention policies",
              "Other bucket metadata"
            ],
            "export_constraints": [
              "Buckets with custom Cloud KMS keys not supported as export destination",
              "Buckets with retention policies not supported as export destination"
            ],
            "machine_readable": true
          }
        ],
        "notes": "Exports to Cloud Storage in JSONL format. Each line is a complete JSON object. Does not provide detailed field schema in export documentation - refer to Asset Types Reference."
      },
      {
        "name": "VPC Service Controls API (Access Context Manager)",
        "type": "REST API",
        "access_method": "API",
        "documentation_url": "https://docs.cloud.google.com/vpc-service-controls/docs/service-perimeters",
        "security_dimensions_covered": [
          {
            "dimension": "Network Isolation",
            "configuration_elements": [
              {
                "element": "Service Perimeter",
                "json_fields": [
                  "name",
                  "title",
                  "perimeterType",
                  "status.resources (project list)",
                  "status.restrictedServices (e.g., storage.googleapis.com)",
                  "status.vpcAccessibleServices",
                  "status.ingressPolicies",
                  "status.egressPolicies",
                  "spec (dry run configuration)",
                  "useExplicitDryRunSpec",
                  "etag"
                ]
              },
              {
                "element": "Ingress Rules",
                "json_fields": [
                  "sources (identityType, identity, project)",
                  "services (attributes)"
                ]
              },
              {
                "element": "Egress Rules",
                "json_fields": [
                  "identity",
                  "project",
                  "service (attributes)"
                ]
              }
            ],
            "modes": [
              "Enforced mode - Requests violating policy are denied",
              "Dry run mode - Requests violating policy are logged but not denied"
            ],
            "machine_readable": true
          }
        ],
        "notes": "JSON/YAML configuration for perimeters. Restricts storage.googleapis.com via restrictedServices array. Ingress/egress rules support context-aware access."
      }
    ]
