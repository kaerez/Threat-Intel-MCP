  "tier_0_sources": {
    "description": "Machine-readable APIs and JSON schemas",
    "sources": [
      {
        "name": "Cloud Storage JSON API v1",
        "type": "REST API with JSON Discovery Document",
        "access_method": "API",
        "discovery_endpoint": "https://storage.googleapis.com/$discovery/rest?version=v1",
        "documentation_url": "https://docs.cloud.google.com/storage/docs/json_api/v1",
        "schema_format": "JSON Schema draft-03",
        "security_dimensions_covered": [
          {
            "dimension": "Access Control - IAM",
            "resources": [
              "Buckets.getIamPolicy",
              "Buckets.setIamPolicy",
              "Buckets.testIamPermissions",
              "ManagedFolders.getIamPolicy",
              "ManagedFolders.setIamPolicy"
            ],
            "machine_readable": true
          },
          {
            "dimension": "Access Control - ACLs",
            "resources": [
              "BucketAccessControls (delete, get, insert, list, patch, update)",
              "DefaultObjectAccessControls (delete, get, insert, list, patch, update)",
              "ObjectAccessControls (delete, get, insert, list, patch, update)"
            ],
            "machine_readable": true
          },
          {
            "dimension": "Retention & Compliance",
            "resources": [
              "Buckets.lockRetentionPolicy",
              "Buckets.restore"
            ],
            "machine_readable": true
          }
        ],
        "notes": "Complete REST API with full JSON request/response schemas for all security operations"
      },
      {
        "name": "Security Command Center API v2",
        "type": "REST API",
        "access_method": "API",
        "documentation_url": "https://docs.cloud.google.com/security-command-center/docs/reference/rest",
        "security_dimensions_covered": [
          {
            "dimension": "Security Findings",
            "api_methods": [
              "organizations.sources.findings.list",
              "projects.sources.findings.list",
              "folders.sources.findings.list",
              "organizations.sources.locations.findings.list",
              "organizations.sources.locations.findings.export",
              "organizations.sources.findings.group"
            ],
            "response_fields": [
              "severity (Critical, High, Medium, Low, Unspecified)",
              "state (ACTIVE, INACTIVE, UNSPECIFIED)",
              "muteState",
              "category",
              "resourceId",
              "securityMarks",
              "externalSystems"
            ],
            "machine_readable": true,
            "finding_categories_storage": [
              "PUBLIC_BUCKET_ACL",
              "VulnerabilitySnapshot",
              "VulnerabilityCountBySeverity"
            ]
          },
          {
            "dimension": "Security Health Analytics",
            "detectors": [
              {
                "name": "PUBLIC_BUCKET_ACL",
                "description": "Detects Cloud Storage buckets that are publicly accessible",
                "remediation_supported": true,
                "automation": "Remove public access playbook"
              }
            ],
            "machine_readable": true
          }
        ],
        "notes": "JSON responses for all findings queries. Export to Cloud Storage in JSON/JSONL format supported."
      },
      {
        "name": "Organization Policy Constraints API",
        "type": "REST API",
        "access_method": "API",
        "documentation_url": "https://docs.cloud.google.com/storage/docs/org-policy-constraints",
        "last_updated": "2026-02-05",
        "security_dimensions_covered": [
          {
            "dimension": "Public Access Control",
            "constraints": [
              {
                "id": "constraints/storage.publicAccessPrevention",
                "type": "Boolean",
                "description": "Public access is restricted for all buckets and objects",
                "enforcement": "Hierarchical with inheritFromParent",
                "effect_time": "Up to 10 minutes"
              }
            ],
            "machine_readable": true
          },
          {
            "dimension": "Encryption at Rest",
            "constraints": [
              {
                "id": "constraints/gcp.restrictNonCmekServices",
                "type": "List",
                "description": "Requires customer-managed encryption keys (CMEK) for new and rewritten objects",
                "enforcement": "Project-level key requirement"
              },
              {
                "id": "constraints/gcp.restrictCmekCryptoKeyProjects",
                "type": "List",
                "description": "Rejects requests if CMEK key does not belong to specified project",
                "enforcement": "Key project validation"
              }
            ],
            "machine_readable": true
          },
          {
            "dimension": "Access Control - IAM",
            "constraints": [
              {
                "id": "constraints/storage.uniformBucketLevelAccess",
                "type": "Boolean",
                "description": "New buckets must enable uniform bucket-level access feature (disables ACLs)",
                "enforcement": "Bucket creation time"
              }
            ],
            "machine_readable": true
          },
          {
            "dimension": "Audit Logging",
            "constraints": [
              {
                "id": "constraints/gcp.detailedAuditLoggingMode",
                "type": "Boolean",
                "description": "Cloud Audit Logs include detailed request and response information",
                "enforcement": "Logging configuration"
              }
            ],
            "machine_readable": true
          },
          {
            "dimension": "Authentication & Authorization",
            "constraints": [
              {
                "id": "constraints/storage.restrictAuthTypes",
                "type": "List",
                "description": "Restricts requests using specific authentication types",
                "allowed_values": [
                  "SERVICE_ACCOUNT_HMAC_SIGNED_REQUESTS",
                  "USER_ACCOUNT_HMAC_SIGNED_REQUESTS",
                  "RSA_SIGNED_REQUESTS",
                  "in:ALL_HMAC_SIGNED_REQUESTS",
                  "in:ALL_SIGNED_REQUESTS"
                ],
                "enforcement": "Request-time validation"
              }
            ],
            "machine_readable": true
          },
          {
            "dimension": "Encryption in Transit",
            "constraints": [
              {
                "id": "constraints/storage.secureHttpTransport",
                "type": "Boolean",
                "description": "All unencrypted HTTP access to Cloud Storage resources is denied (requires HTTPS)",
                "enforcement": "Request-time validation"
              },
              {
                "id": "constraints/gcp.restrictTLSVersion",
                "type": "List",
                "description": "Prevents TLS 1.0/1.1 access",
                "enforcement": "Connection-time validation"
              }
            ],
            "machine_readable": true
          },
          {
            "dimension": "Data Lifecycle & Retention",
            "constraints": [
              {
                "id": "constraints/storage.softDeletePolicySeconds",
                "type": "List",
                "description": "Specifies permitted soft delete durations; required for new buckets",
                "enforcement": "Bucket policy configuration"
              },
              {
                "id": "constraints/storage.retentionPolicySeconds",
                "type": "List",
                "description": "Enforces specific retention durations for bucket retention policies",
                "enforcement": "Bucket policy configuration"
              }
            ],
            "machine_readable": true
          }
        ],
        "notes": "Constraints are defined and retrieved via REST API in JSON format. Supports hierarchical enforcement with inheritFromParent field."
      },
      {
        "name": "Cloud Audit Logs API",
        "type": "Structured Log Schema (JSON)",
        "access_method": "Cloud Logging API",
        "documentation_url": "https://docs.cloud.google.com/storage/docs/audit-logging",
        "log_entry_schema": "https://cloud.google.com/logging/docs/reference/v2/rest/v2/LogEntry",
        "audit_log_schema": "https://cloud.google.com/logging/docs/reference/audit/auditlog/rest/Shared.Types/AuditLog",
        "security_dimensions_covered": [
          {
            "dimension": "Audit Logging - All Operations",
            "log_types": [
              {
                "type": "Admin Activity (ADMIN_WRITE)",
                "description": "Configuration modifications including IAM policies, bucket creation, deletion, HMAC key management",
                "enabled_by_default": true
              },
              {
                "type": "Data Access - ADMIN_READ",
                "description": "Metadata reads: Getting bucket/folder IAM policies, listing buckets",
                "enabled_by_default": false,
                "requires_explicit_enable": true
              },
              {
                "type": "Data Access - DATA_READ",
                "description": "Getting object data, getting object metadata, listing objects",
                "enabled_by_default": false,
                "requires_explicit_enable": true
              },
              {
                "type": "Data Access - DATA_WRITE",
                "description": "Creating objects, deleting objects, multipart upload operations",
                "enabled_by_default": false,
                "requires_explicit_enable": true
              },
              {
                "type": "System Event",
                "description": "Bucket relocation process start/end events generated by Google systems",
                "enabled_by_default": true
              }
            ],
            "json_structure": {
              "LogEntry": {
                "logName": "Resource ID and audit log type identifier",
                "resource": "Target of the audited operation",
                "timestamp": "Operation time (RFC 3339)",
                "protoPayload": "AuditLog object"
              },
              "AuditLog": {
                "@type": "type.googleapis.com/google.cloud.audit.AuditLog",
                "serviceName": "storage.googleapis.com",
                "principalEmail": "User identity (may be redacted)",
                "callerIp": "Source IP address",
                "authenticationInfo": "Authentication details",
                "metadata": "Cloud Storage-specific information (e.g., destination bucket for rewrites)",
                "request": "Additional audit details when detailed logging enabled",
                "response": "Additional audit details when detailed logging enabled",
                "audit_info": "Custom metadata from x-goog-custom-audit-KEY headers (64 char key, 1200 char value max)"
              }
            },
            "machine_readable": true
          }
        ],
        "notes": "Complete JSON schema available. Detailed request/response fields populated when gcp.detailedAuditLoggingMode constraint is enabled."
      },
      {
        "name": "Policy Intelligence Recommender API",
        "type": "REST API",
        "access_method": "API",
        "documentation_url": "https://docs.cloud.google.com/policy-intelligence/docs/review-apply-role-recommendations-buckets",
        "api_endpoint": "recommender.googleapis.com",
        "security_dimensions_covered": [
          {
            "dimension": "IAM Role Optimization",
            "recommendation_types": [
              {
                "recommenderSubtype": "REMOVE_ROLE_STORAGE_BUCKET",
                "description": "Role has not been used during the 90-day observation window",
                "priority": "P1",
                "security_improvement": "Reduces attack surface by revoking unused permissions"
              },
              {
                "recommenderSubtype": "REPLACE_ROLE_STORAGE_BUCKET",
                "description": "Proposes substituting current roles with more restrictive predefined or custom roles aligned with usage patterns",
                "priority": "P1",
                "security_improvement": "Enforces least-privilege access through narrower role scopes"
              }
            ],
            "json_response_schema": {
              "name": "projects/{PROJECT_ID}/locations/{LOCATION}/recommenders/google.iam.policy.Recommender/recommendations/{RECOMMENDATION_ID}",
              "description": "string",
              "lastRefreshTime": "timestamp",
              "primaryImpact": {
                "category": "SECURITY",
                "securityProjection": {
                  "details": {
                    "revokedIamPermissionsCount": "number"
                  }
                }
              },
              "content": {
                "operationGroups": [
                  {
                    "operations": [
                      {
                        "action": "remove|replace",
                        "resourceType": "storage.googleapis.com/Bucket",
                        "resource": "//storage.googleapis.com/{BUCKET_NAME}",
                        "path": "/iamPolicy/bindings/*/members/*",
                        "pathFilters": {}
                      }
                    ]
                  }
                ]
              },
              "stateInfo": {
                "state": "ACTIVE|CLAIMED|SUCCEEDED|FAILED"
              },
              "etag": "string",
              "recommenderSubtype": "REMOVE_ROLE_STORAGE_BUCKET|REPLACE_ROLE_STORAGE_BUCKET",
              "associatedInsights": [],
              "priority": "P1"
            },
            "machine_readable": true,
            "observation_window": "90 days"
          }
        ],
        "notes": "ML-generated recommendations in JSON format. Supports state transitions via API. Uses json or yaml format for API operations."
      },
      {
        "name": "Cloud Asset Inventory API",
        "type": "REST API with JSON/JSONL Export",
        "access_method": "API",
        "documentation_url": "https://docs.cloud.google.com/asset-inventory/docs/export-cloud-storage",
        "last_updated": "2026-02-02, 2026-02-05",
        "security_dimensions_covered": [
          {
            "dimension": "Asset Metadata Export",
            "export_format": "Newline-delimited JSON (JSONL)",
