  "response_shape_contracts": [
    {
      "description": "All tools return data + metadata envelope",
      "applies_to": "all",
      "expected_top_keys": ["data", "metadata"],
      "metadata_keys": ["query_time_ms", "cache_hit", "data_freshness"]
    },
    {
      "description": "Search tools return paginated results",
      "applies_to": ["search_cve", "search_techniques", "search_threat_actors", "search_atlas_techniques", "search_atlas_case_studies", "search_capec_patterns", "search_capec_mitigations", "search_cwe_weaknesses", "search_defenses", "search_cloud_services", "search_owasp_llm_vulnerabilities"],
      "expected_data_keys": ["total_results"]
    },
    {
      "description": "Semantic search tools return similarity scores",
      "applies_to": ["find_similar_techniques", "find_similar_threat_actors", "find_similar_atlas_techniques", "find_similar_atlas_case_studies", "find_similar_capec_patterns", "find_similar_capec_mitigations", "find_similar_cwe_weaknesses", "find_similar_defenses"],
      "requires_openai_api_key": true
    },
    {
      "description": "Detail tools may return null data for non-existent IDs",
      "applies_to": ["get_cve_details", "get_cwe_weakness_details", "get_cwe_details"],
      "data_nullable": true
    },
    {
      "description": "Metadata always includes timing and freshness info",
      "applies_to": "all",
      "metadata_schema": {
        "query_time_ms": "integer",
        "cache_hit": "boolean",
        "data_freshness": "string",
        "last_sync_time": "string|null",
        "data_age_hours": "integer|null"
      }
    }
  ]
