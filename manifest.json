{
  "manifest_version": "0.3",
  "name": "threat-intel-mcp",
  "display_name": "Threat Intelligence MCP Server",
  "version": "1.3.0",
  "description": "Threat Intelligence MCP Server - CVE, ATT&CK, Cloud Security, threat actors, semantic search",
  "author": {
    "name": "Ansvar Systems",
    "email": "hello@ansvar.eu",
    "url": "https://ansvar.eu"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ansvar-Systems/threat-intel-mcp"
  },
  "homepage": "https://ansvar.eu",
  "keywords": ["cve", "mcp", "security", "vulnerability", "nvd", "epss", "cisa-kev", "mitre-attack", "threat-intelligence", "apt", "threat-actors", "semantic-search", "rag"],
  "server": {
    "type": "python",
    "entry_point": "run.py",
    "mcp_config": {
      "command": "python3",
      "args": ["${__dirname}/run.py"],
      "env": {
        "PYTHONPATH": "${__dirname}/src:${__dirname}/lib"
      }
    }
  },
  "tools": [],
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"],
    "runtimes": {
      "python": ">=3.11"
    }
  }
}
